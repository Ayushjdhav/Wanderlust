<% layout("/layouts/boilerplate.ejs") -%>

    <div class="filters-container">

        <div id="filters">

            <div class="filter active" data-category="all">
                <i class="fa-solid fa-border-all"></i>
                <p>All</p>
            </div>

            <div class="filter" data-category="trending">
                <i class="fa-solid fa-fire"></i>
                <p>Trending</p>
            </div>

            <div class="filter" data-category="rooms">
                <i class="fa-solid fa-bed"></i>
                <p>Rooms</p>
            </div>

            <div class="filter" data-category="iconic-cities">
                <i class="fa-solid fa-city"></i>
                <p>Iconic Cities</p>
            </div>

            <div class="filter" data-category="mountains">
                <i class="fa-solid fa-mountain"></i>
                <p>Mountains</p>
            </div>

            <div class="filter" data-category="amazing-views">
                <i class="fa-solid fa-water"></i>
                <p>Amazing Views</p>
            </div>

            <div class="filter" data-category="beach">
                <i class="fa-solid fa-umbrella-beach"></i>
                <p>Beach</p>
            </div>

            <div class="filter" data-category="camping">
                <i class="fa-solid fa-campground"></i>
                <p>Camping</p>
            </div>

            <div class="filter" data-category="castles">
                <i class="fa-solid fa-chess-rook"></i>
                <p>Castles</p>
            </div>

            <div class="filter" data-category="arctic">
                <i class="fa-solid fa-snowflake"></i>
                <p>Arctic</p>
            </div>

            <div class="filter" data-category="farms">
                <i class="fa-solid fa-tractor"></i>
                <p>Farms</p>
            </div>

            <div class="filter" data-category="pools">
                <i class="fa-solid fa-person-swimming"></i>
                <p>Pools</p>
            </div>

            <div class="filter" data-category="forest">
                <i class="fa-solid fa-tree"></i>
                <p>Forest</p>
            </div>

        </div>

        <!-- GST Toggle -->
        <div class="tax-toggle">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">
                    Display Total after taxes
                </label>
            </div>
        </div>

    </div>

    <% if(allListings.length===0){ %>

        <div class="text-center mt-5">
            <h3>No Listings Found</h3>
            <a href="/listings" class="btn btn-dark mt-3">Back to Home</a>
        </div>

        <% } else { %>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 mt-3">

                <% for(let listing of allListings){ %>

                    <div class="col">

                        <a href="/listings/<%= listing._id %>" class="listing-links">

                            <div class="card listing-card h-100">

                                <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=800' %>"
                                    loading="lazy" class="card-img-top" alt="<%= listing.title %>">

                                <div class="card-img-overlay"></div>

                                <div class="card-body">

                                    <h5 class="card-title mb-1">
                                        <%= listing.title %>
                                    </h5>

                                    <p class="card-text mb-1">
                                        <strong>₹ <%= listing.price.toLocaleString("en-IN") %></strong>
                                        <span class="text-muted"> / night</span>

                                        <span class="tax-info text-success">
                                            +18% GST
                                        </span>
                                    </p>

                                    <p class="text-muted small mb-0">
                                        📍 <%= listing.location %>, <%= listing.country %>
                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>

                    <% } %>

            </div>

            <% } %>